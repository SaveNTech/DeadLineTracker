# Copy this file to .env and fill in real values. Never commit .env.

# --- Postgres (used by docker-compose and by the backend) ---
POSTGRES_USER=deadline_tracker
POSTGRES_PASSWORD=change-me
POSTGRES_DB=deadline_tracker
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Host ports (docker-compose only) ---
# Change these if the defaults are already taken on the host (e.g. a shared
# server already running other projects).
DB_HOST_PORT=5433
BACKEND_HOST_PORT=8000

# Async SQLAlchemy URL used by the backend app
DATABASE_URL=postgresql+asyncpg://deadline_tracker:change-me@db:5432/deadline_tracker

# --- Auth ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Prefix used on issued personal API tokens (third-party integrations)
API_TOKEN_PREFIX=dt_live_

# --- App ---
ENVIRONMENT=local
BACKEND_CORS_ORIGINS=["http://localhost","http://localhost:3000"]
